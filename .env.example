# =============================================================================
# Estuaire — Environment Variables
# =============================================================================
# Copy this file or use it as reference. In dev, secrets live in
# .env.development (encrypted in git via git-crypt, plaintext on disk).
# In production, variables are set in the Coolify UI.
# =============================================================================

# --- Sanity (public — inlined in client bundle) ---
NEXT_PUBLIC_SANITY_PROJECT_ID=   # Sanity Cloud project ID (e.g. "abc123de")
NEXT_PUBLIC_SANITY_DATASET=      # Dataset name (e.g. "production")

# --- Site (public) ---
NEXT_PUBLIC_SITE_URL=            # Canonical site URL (e.g. "https://estuaire.fr")

# --- Sanity (server-only) ---
SANITY_API_READ_TOKEN=           # Sanity API read token (Viewer role) — used by Live Content API and Draft Mode

# --- Revalidation (server-only) ---
REVALIDATION_SECRET=             # Shared secret for Sanity webhook (e.g. "whsec_...")
