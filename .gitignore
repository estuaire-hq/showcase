# Sanity TypeGen — `src/sanity.types.ts` IS committed (source of shared content
# types, see ADR 0006). Only the intermediate schema representations are ignored:
# - schema.json : typegen intermediate (regenerated by `npm run typegen`)
# - .sanity/    : enforced-required schema + asset manifest used by seed --check/scaffold
schema.json
.sanity/

# Vercel
.vercel

# Spec Kit — extensions (installed locally, not shared)
.specify/extensions/

# Turbo
.turbo

# Playwright
.playwright-mcp/

# /dispatch — per-worktree briefing scratch file (ADR 0015), never committed
.dispatch/
